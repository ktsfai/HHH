HASH256_RPC_URL=https://go.getblock.io/your-ethereum-json-rpc-key
HASH256_SUBMIT_RPC_URL=https://rpc.flashbots.net/fast
# 只做搜索时填地址即可；自动提交时可不填，程序会从私钥推导
HASH256_MINER_ADDRESS=0xYourMinerAddress
# 自动提交时再填写，建议使用单独的钱包
HASH256_PRIVATE_KEY=0xYourPrivateKey
HASH256_BACKEND=metal
HASH256_THREADS=7
HASH256_BATCH_SIZE=1048576
HASH256_SUBMIT=0
HASH256_KEEP_MINING=1
HASH256_POLL_INTERVAL=12
HASH256_MIN_PRIORITY_FEE_GWEI=2.5
HASH256_MAX_FEE_MULTIPLIER=3
HASH256_MAX_PENDING_SUBMISSIONS=1
